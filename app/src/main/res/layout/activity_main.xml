<?xml version="1.0" encoding="utf-8"?>
<!-- Layout PORTRAIT (Vertical) - Diseño mejorado con header -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Header fijo con el título de la app -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/header_gradient"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:elevation="6dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textSize="14sp"
            android:textColor="#E3F2FD"
            android:gravity="center"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Contenido con scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tarjeta de contenido -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:elevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título del Producto -->
                    <TextView
                        android:id="@+id/productTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/product_title"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2"
                        android:layout_marginBottom="12dp"
                        android:gravity="center"/>

                    <!-- Imagen del Producto (Ahora más abajo) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"
                        android:elevation="4dp">

                        <ImageView
                            android:id="@+id/productImage"
                            android:layout_width="match_parent"
                            android:layout_height="280dp"
                            android:contentDescription="@string/product_image_desc"
                            android:scaleType="centerCrop"
                            android:src="@drawable/nintendoswitch2"
                            android:background="#F5F5F5"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Precio del Producto (destacado) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="#E8F5E9"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Precio especial:"
                            android:textSize="16sp"
                            android:textColor="#388E3C"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/productPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/product_price"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"/>
                    </LinearLayout>

                    <!-- Descripción del Producto -->
                    <TextView
                        android:id="@+id/productDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/product_description"
                        android:textSize="15sp"
                        android:textColor="#424242"
                        android:layout_marginBottom="20dp"
                        android:lineSpacingExtra="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tarjeta de Características -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:elevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FAFAFA">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/features_title"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/productFeatures"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/product_features"
                        android:textSize="15sp"
                        android:textColor="#424242"
                        android:lineSpacingExtra="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón de Comprar -->
            <Button
                android:id="@+id/buyButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/buy_button"
                android:textSize="19sp"
                android:textStyle="bold"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF"
                android:elevation="8dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

